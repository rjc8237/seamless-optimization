      "skip": false,
      "args_list": [
        {}
      ]
    },
    {
      "method": "similarity_overlay",
      "skip": false,
      "args_list": [
        {
        }
      ]
    },
    {
      "method": "similarity_histogram",
      "skip": false,
      "args_list": [
        {
          "bin_min": 1.0,
          "bin_max": 1.5,
          "ylim": 100
        }
      ]
    },
    {
      "method": "render_uv",
      "skip": true,
      "args_list": [
        {
          "suffix": "refined_with_uv"
        }
      ]
    }
  ]
